{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bash scripts/setup-aireon-shared-ssh.sh && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/three3d/:op", "destination": "/api/three3d?path=:op" }
  ]
}
