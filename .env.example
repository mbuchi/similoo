# Signal-collect proxy configuration.
# All variables are optional: when unset, the function falls back to the
# upstream URL and bearer token used by the original Netlify deployment.

# Preferred names (Vercel project settings):
SIGNAL_COLLECT_API_URL=https://res.zeroo.ch/res_api/signal/collect
SIGNAL_COLLECT_API_TOKEN=your-bearer-token-without-the-Bearer-prefix

# Cesium Ion access token. Required for the "3D OSM + Cesium terrain"
# preset (OSM Buildings Ion asset id 96188 + Cesium World Terrain Ion
# asset id 1). When unset, the toggle is shown disabled with a
# "Set VITE_CESIUM_ION_TOKEN to enable" hint and no Ion request is
# fired. The Swiss and Google presets don't use Ion and are unaffected.
VITE_CESIUM_ION_TOKEN=your-cesium-ion-token

# Mapbox public (pk.*) token used by forward + reverse address geocoding.
# Without this, the navbar search and GPS reverse-geocode will return no
# results. Use a publishable (pk.*) token — never a secret (sk.*) token.
VITE_MAPBOX_TOKEN=your-mapbox-public-token

# Google Maps Platform "Map Tiles API" key. Required for the "Google
# Photorealistic 3D" preset. When unset, the toggle is shown disabled
# with a "Set VITE_GOOGLE_MAPS_API_KEY to enable" hint and no request
# is fired. The Swiss and OSM presets are unaffected.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-tiles-api-key
